{
  "name": "abaprfc",
  "displayName": "abaprfc",
  "description": "RFC connection to SAP (requires Python, PyRFC, and SAP NW RFC SDK)",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.66.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ABAP",
    "sap",
    "filesystem",
    "remote"
  ],
  "extensionDependencies": [
    "larshp.vscode-abap",
    "vscode.git"
  ],
  "activationEvents": [
    "onCommand:abaprfc.addConnection",
    "onCommand:abaprfc.editConnection",
    "onCommand:abaprfc.testConnection",
    "onCommand:abaprfc.getProgram",
    "onCommand:abaprfc.getFunction",
    "onCommand:abaprfc.uploadProgram",
    "onCommand:abaprfc.syntaxCheck",
    "onCommand:abaprfc.diffWithSap",
    "onCommand:abaprfc.styleCheck",
    "onCommand:abaprfc.searchProgram",
    "onCommand:abaprfc.searchFunction",
    "onCommand:abaprfc.openWorkspace",
    "onView:abapRfcExplorer",
    "onView:abapRfcSystemsView",
    "onView:abapTransportExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "AbapRfc",
      "properties": {
        "abaprfc.syntaxCheckOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run syntax check (via RFC) when saving an .abap file."
        },
        "abaprfc.styleCheckOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run Clean ABAP style check (offline) when opening or saving an .abap file."
        },
        "abaprfc.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Python interpreter used for RFC bridge calls. Leave empty to auto-detect from PATH or the VS Code Python extension."
        },
        "abaprfc.sapNwRfcSdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to the SAP NW RFC SDK root or lib directory. Leave empty to auto-detect common locations such as C:\\nwrfcsdk\\lib."
        }
      }
    },
    "views": {
      "abapRfcSystems": [
        {
          "id": "abapRfcSystemsView",
          "name": "Systems"
        }
      ],
      "explorer": [
        {
          "id": "abapRfcExplorer",
          "name": "ABAP RFC Explorer"
        },
        {
          "id": "abapTransportExplorer",
          "name": "ABAP Transports"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "abapRfcSystems",
          "title": "ABAP RFC",
          "icon": "resources/systems.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "abaprfc.addConnection",
        "title": "AbapRfc: Add SAP Connection"
      },
      {
        "command": "abaprfc.editConnection",
        "title": "AbapRfc: Edit SAP Connection",
        "icon": "$(edit)"
      },
      {
        "command": "abaprfc.testConnection",
        "title": "AbapRfc: Test SAP Connection",
        "icon": "$(plug)"
      },
      {
        "command": "abaprfc.getProgram",
        "title": "AbapRfc: Download Program from SAP"
      },
      {
        "command": "abaprfc.getFunction",
        "title": "AbapRfc: Download Function Module from SAP"
      },
      {
        "command": "abaprfc.uploadProgram",
        "title": "AbapRfc: Upload to SAP",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "abaprfc.syntaxCheck",
        "title": "AbapRfc: Syntax Check",
        "icon": "$(check)"
      },
      {
        "command": "abaprfc.diffWithSap",
        "title": "AbapRfc: Diff with SAP",
        "icon": "$(diff)"
      },
      {
        "command": "abaprfc.searchProgram",
        "title": "AbapRfc: Search Programs in SAP",
        "icon": "$(search)"
      },
      {
        "command": "abaprfc.searchFunction",
        "title": "AbapRfc: Search Function Modules in SAP",
        "icon": "$(search)"
      },
      {
        "command": "abaprfc.styleCheck",
        "title": "AbapRfc: Style Check (Clean ABAP)",
        "icon": "$(book)"
      },
      {
        "command": "abaprfc.openWorkspace",
        "title": "AbapRfc: Open ABAP Workspace"
      },
      {
        "command": "abapRfcExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "abapRfcSystemsView.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "abapTransportExplorer.refresh",
        "title": "Refresh Transports",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "abapRfcExplorer.refresh",
          "when": "view == abapRfcExplorer",
          "group": "navigation"
        },
        {
          "command": "abapRfcSystemsView.refresh",
          "when": "view == abapRfcSystemsView",
          "group": "navigation"
        },
        {
          "command": "abaprfc.addConnection",
          "when": "view == abapRfcSystemsView",
          "group": "navigation@1"
        },
        {
          "command": "abapTransportExplorer.refresh",
          "when": "view == abapTransportExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "abaprfc.testConnection",
          "when": "view == abapRfcSystemsView && viewItem == sapSystem",
          "group": "inline@1"
        },
        {
          "command": "abaprfc.editConnection",
          "when": "view == abapRfcSystemsView && viewItem == sapSystem",
          "group": "inline@2"
        }
      ],
      "editor/title": [
        {
          "command": "abaprfc.diffWithSap",
          "when": "resourceExtname == .abap",
          "group": "navigation@1"
        },
        {
          "command": "abaprfc.uploadProgram",
          "when": "resourceExtname == .abap",
          "group": "navigation@2"
        },
        {
          "command": "abaprfc.syntaxCheck",
          "when": "resourceExtname == .abap",
          "group": "navigation@3"
        },
        {
          "command": "abaprfc.styleCheck",
          "when": "resourceExtname == .abap",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "abaprfc.diffWithSap",
          "when": "resourceExtname == .abap",
          "group": "abaprfc@1"
        },
        {
          "command": "abaprfc.uploadProgram",
          "when": "resourceExtname == .abap",
          "group": "abaprfc@2"
        },
        {
          "command": "abaprfc.syntaxCheck",
          "when": "resourceExtname == .abap",
          "group": "abaprfc@3"
        },
        {
          "command": "abaprfc.styleCheck",
          "when": "resourceExtname == .abap",
          "group": "abaprfc@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "abaprfc.uploadProgram",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u",
        "when": "resourceExtname == .abap"
      },
      {
        "command": "abaprfc.syntaxCheck",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "resourceExtname == .abap"
      },
      {
        "command": "abaprfc.diffWithSap",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "resourceExtname == .abap"
      },
      {
        "command": "abaprfc.styleCheck",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "resourceExtname == .abap"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npm run compile && npx mocha --ui tdd out/test/unit/**/*.test.js --timeout 5000"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mkdirp": "^0.5.2",
    "@types/mocha": "^9.1.0",
    "@types/node": "14.x",
    "@types/rimraf": "^3.0.2",
    "@types/vscode": "^1.66.0",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "@vscode/test-electron": "^2.1.3",
    "abap-api-tools": "^2.3.1",
    "cmake-js": "^6.3.0",
    "electron": "^18.1.0",
    "electron-rebuild": "^3.2.7",
    "eslint": "^8.11.0",
    "glob": "^7.2.0",
    "mocha": "^9.2.2",
    "typescript": "^4.5.5"
  },
  "dependencies": {
    "@redhat-developer/vscode-wizard": "^0.2.30"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/siasty/abaprfc/issues",
    "email": "maciej.miskiewicz83@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/siasty/abaprfc.git"
  }
}
